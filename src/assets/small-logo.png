import { NotificationsPage } from '@/pages/NotificationsPage.jsx';
import InvoicePage from '@/pages/InvoicePage.jsx';
import HostRequestValidationPage from '@/pages/admin/HostRequestValidationPage.jsx';
import BookingConfirmationPage from '@/pages/admin/BookingConfirmationPage.jsx';
import FocusedLayout from '@/layouts/FocusedLayout.jsx';
import { ClinicBookingPage } from '@/pages/ClinicBookingPage.jsx';
import SupportChatWidget from '@/components/support/SupportChatWidget.jsx';
import { useAuth } from '@/contexts/SupabaseAuthContext.jsx';
import smallLogo from '@/assets/small-logo.png';

const MainLayout = () => {
  const { user } = useAuth();
  return <div className="flex flex-col min-h-screen bg-background font-sans">
          <Navbar />
          <AuthRedirector />
          <main className="flex-grow container max-w-screen-2xl mx-auto py-6 sm:py-8 px-4 sm:px-6">
            <Outlet />
          </main>

          <footer className="py-8 sm:py-12 mt-auto border-t bg-background/95">
            <div className="container max-w-screen-2xl mx-auto px-4 sm:px-6">
              <div className="grid grid-cols-1 md:grid-cols-4 gap-8">
                <div className="flex flex-col items-center md:items-start">
                    <div className="flex items-center space-x-2 mb-2">
                        <img alt="Goldent Co Work Small Logo" className="h-7 sm:h-8 w-auto" src={smallLogo} />
                        <span className="font-semibold text-sm sm:text-base gradient-text">Goldent Co Work</span>
                    </div>
                    <p className="text-xs sm:text-sm text-muted-foreground text-center md:text-left">
                    Conectando odontólogos y clínicas en República Dominicana.
                    </p>
                </div>
                <div className="text-center md:text-left">
                  <p className="font-semibold mb-2">Legal</p>
                  <ul className="space-y-2 text-sm text-muted-foreground">
                    <li><Link to="/policies" className="hover:text-primary">Términos y Condiciones</Link></li>
                    <li><Link to="/policies" className="hover:text-primary">Política de Privacidad</Link></li>
                    <li><Link to="/policies" className="hover:text-primary">Política de Pagos</Link></li>
                  </ul>
                </div>
                <div className="text-center md:text-left">
                  <p className="font-semibold mb-2">Comunidad</p>
                  <ul className="space-y-2 text-sm text-muted-foreground">
                    <li><Link to="/policies" className="hover:text-primary">Reglas de Convivencia</Link></li>
                    <li><Link to="/register-clinic-host" className="hover:text-primary">Conviértete en Anfitrión</Link></li>
                  </ul>
                </div>
                <div className="text-center md:text-left">
                  <p className="font-semibold mb-2">Soporte</p>
                  <ul className="space-y-2 text-sm text-muted-foreground">
                    <li><Link to="/policies" className="hover:text-primary">Contacto Legal</Link></li>
                    <li><Link to="/policies" className="hover:text-primary">Resolución de Conflictos</Link></li>
                  </ul>
                </div>
              </div>
              <div className="text-center text-xs sm:text-sm text-muted-foreground mt-8 pt-8 border-t">
                  <p>&copy; {new Date().getFullYear()} Goldent Co Work. Todos los derechos reservados.</p>
                  <p>Hecho con <span role="img" aria-label="corazón">💛</span> y mucho café.</p>
              </div>
            </div>
          </footer>
          {user && <SupportChatWidget />}
        </div>;
};

